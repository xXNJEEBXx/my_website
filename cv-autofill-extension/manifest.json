{
  "manifest_version": 3,
  "name": "CV AutoFill — Agent Tool",
  "version": "1.0.0",
  "description": "Auto-fills job application forms. Exposes window.__CV_AGENT.fill() for browser agent use.",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["data.js", "ui.js", "engine.js", "content.js"],
      "all_frames": true,
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CV AutoFill"
  },
  "permissions": ["scripting", "activeTab"]
}
